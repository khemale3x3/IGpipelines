# Copy to .env and fill values (do NOT commit secrets)
# Comma-separated Instagram sessionid cookie values
IG_SESSION_IDS=SESSIONID1,SESSIONID2

# Default CLI options (used when --flag is not passed)
DEFAULT_INPUT=data/input_sample.csv
DEFAULT_OUTPUT_DIR=data/output
DEFAULT_ANALYZED=data/analyzed.json
DEFAULT_CSV=data/report.csv
DEFAULT_SSA=data/unique_names_ssa.txt
DEFAULT_WORKERS=2
DEFAULT_TEST_PROFILES=5
DEFAULT_MAX_SCROLLS=1

# Toggle test scraping mode (true/false)
DEFAULT_TEST=false
